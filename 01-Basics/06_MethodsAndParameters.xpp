class Dev06_MethodsAndParameters
{
    private static int add(int _a, int _b)
    {
        return _a + _b;
    }

    private static str formatMessage(str _name, int _value)
    {
        return strFmt("Usuario %1 - Valor %2", _name, _value);
    }

    public static void main(Args _args)
    {
        int total = Dev06_MethodsAndParameters::add(10, 20);
        info(Dev06_MethodsAndParameters::formatMessage("Admin", total));
    }
}